# Python 缓存
__pycache__/
*.py[cod]
*.so

# 虚拟环境与本地引导目录
.venv/
env/
venv/
.env
.gradio/
# 工具缓存与覆盖率产物
htmlcov/
.coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# 日志与编辑器临时文件
*.log
*.swp
.DS_Store

# 本地模型下载，不上传
models/

# 推理与评测结果产物默认忽略，仅保留整理后的归档与报告
/results/*
!/results/README.md
!/results/quantitative_report.md
!/results/quantitative_report.txt
!/results/benchmark_suite_*/
!/results/benchmark_suite_*/**

# 评测数据通过 Git LFS 远程保留

# 训练输出默认不上传；baseline 文本结果可保留
outputs/*
!outputs/README.md
!outputs/r4_lora_variant_baseline_results.txt
!outputs/baseline/
outputs/baseline/*
!outputs/baseline/**
!outputs/qwen3_8b_lora_ddi_ade_latest_raw_clean_balanced_e3/
!outputs/qwen3_8b_lora_ddi_ade_latest_raw_clean_balanced_e3/**
